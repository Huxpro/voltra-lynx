CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Lynx" "${PODS_CONFIGURATION_BUILD_DIR}/LynxBase" "${PODS_CONFIGURATION_BUILD_DIR}/LynxServiceAPI" "${PODS_CONFIGURATION_BUILD_DIR}/PrimJS"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Lynx/Lynx.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/LynxBase/LynxBase.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/LynxServiceAPI/LynxServiceAPI.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/PrimJS/PrimJS.framework/Headers"
OTHER_CFLAGS = $(inherited) -isystem "${PODS_CONFIGURATION_BUILD_DIR}/Lynx/Lynx.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/LynxBase/LynxBase.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/LynxServiceAPI/LynxServiceAPI.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/PrimJS/PrimJS.framework/Headers" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/Lynx" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/LynxBase" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/LynxServiceAPI" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/PrimJS"
OTHER_LDFLAGS = $(inherited) -ObjC -l"stdc++" -framework "AudioToolbox" -framework "JavaScriptCore" -framework "Lynx" -framework "LynxBase" -framework "LynxServiceAPI" -framework "NaturalLanguage" -framework "PrimJS" -framework "UIKit" -framework "WebKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/Lynx" "-F${PODS_CONFIGURATION_BUILD_DIR}/LynxBase" "-F${PODS_CONFIGURATION_BUILD_DIR}/LynxServiceAPI" "-F${PODS_CONFIGURATION_BUILD_DIR}/PrimJS"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
