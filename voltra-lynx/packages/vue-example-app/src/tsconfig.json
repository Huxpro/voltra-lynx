{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vue-lynx/types", "@lynx-js/types"],
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "vueCompilerOptions": {
    "plugins": ["vue-lynx/types/volar-plugin"]
  },
  "include": ["./**/*.ts", "./**/*.vue"]
}
