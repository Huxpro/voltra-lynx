      "types": "./dist/android-client/index.d.ts",
      "import": "./dist/android-client/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@use-voltra/ios": "^1.4.0",
    "@use-voltra/android": "^1.4.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "~5.8.0"
